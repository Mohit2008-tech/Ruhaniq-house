# Ruhaniq House Environment Variables
# Copy this file to .env and fill in your values

# WhatsApp Business Number (with country code, no +)
VITE_WA_NUMBER=your_whatsapp_number

# Instagram Profile URL
VITE_IG_URL=https://www.instagram.com/your_instagram/

# Google Apps Script URL for form submissions
VITE_GOOGLE_SHEET_URL=your_google_apps_script_url
